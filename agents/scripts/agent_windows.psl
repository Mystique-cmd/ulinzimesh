# Real Windows agent - captures live TCP connections and posts to collector
$CollectorUrl = $env:COLLECTOR_URL
if (-not $CollectorUrl) {
    $CollectorUrl = "http://127.0.0.1:9090/ingest/flow"
}

$hostname = $env:COMPUTERNAME
$platform = "windows"

# Capture real TCP connections using Get-NetTCPConnection
$connections = Get-NetTCPConnection -ErrorAction SilentlyContinue | Where-Object {
    $_.State -ne "Listen" -and $_.RemoteAddress -ne "0.0.0.0" -and $_.RemotePort -ne 0
}

if ($connections -and $connections.Count -gt 0) {
    foreach ($conn in $connections) {
        $src_ip = $conn.LocalAddress
        $src_port = $conn.LocalPort
        $dst_ip = $conn.RemoteAddress
        $dst_port = $conn.RemotePort
        $protocol = "tcp"
        $direction = "egress"
        $bytes_tx = 0
        $bytes_rx = 0

        # Determine direction based on state
        if ($conn.State -eq "CloseWait" -or $conn.State -eq "LastAck") {
            $direction = "ingress"
        }

        $event = [pscustomobject]@{
            hostname = $hostname
            platform = $platform
            src_ip = $src_ip
            src_port = $src_port
            dst_ip = $dst_ip
            dst_port = $dst_port
            protocol = $protocol
            direction = $direction
            bytes_tx = $bytes_tx
            bytes_rx = $bytes_rx
        }

        $eventJson = $event | ConvertTo-Json -Compress -ErrorAction SilentlyContinue

        try {
            Invoke-RestMethod -Method Post -Uri $CollectorUrl -ContentType "application/json" -Body $eventJson -TimeoutSec 5 -ErrorAction SilentlyContinue | Out-Null
            Write-Host "$(Get-Date -Format o) [agent_windows] posted flow: $src_ip:$src_port -> $dst_ip:$dst_port"
        }
        catch {
            Write-Warning "$(Get-Date -Format 'o') [agent_windows] post failed: $_"

            $scriptPath = Split-Path -Path $MyInvocation.MyCommand.Path
            $spoolDir = Join-Path $scriptPath "../../spool/outbox"
            if (-not (Test-Path $spoolDir)) {
                New-Item -ItemType Directory -Force -Path $spoolDir | Out-Null
            }
            $fname = Join-Path $spoolDir ("{0:yyyyMMddTHHmmss}_$PID.json" -f (Get-Date))
            $eventJson | Out-File -Encoding ascii -FilePath $fname
        }
    }
}
else {
    # No real connections found - output a minimal synthetic event to keep pipeline alive
    $event = [pscustomobject]@{
        hostname = $hostname
        platform = $platform
        src_ip = "127.0.0.1"
        src_port = 0
        dst_ip = "127.0.0.1"
        dst_port = 0
        protocol = "tcp"
        direction = "egress"
        bytes_tx = 0
        bytes_rx = 0
    }
    $eventJson = $event | ConvertTo-Json -Compress

    try {
        Invoke-RestMethod -Method Post -Uri $CollectorUrl -ContentType "application/json" -Body $eventJson -TimeoutSec 5 | Out-Null
        Write-Host "$(Get-Date -Format o) [agent_windows] posted synthetic event (no real connections found)"
    }
    catch {
        Write-Warning "$(Get-Date -Format 'o') [agent_windows] post failed: $_"
    }
}

